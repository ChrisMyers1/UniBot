# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Application (client) ID from the same dev portal page
CLIENT_ID=your_application_client_id_here

# Postgres connection string
# Local docker example: postgresql://postgres:postgres@localhost:5432/timebot?schema=public
# Railway/Supabase: they give you this string directly
DATABASE_URL=postgresql://user:password@localhost:5432/timebot?schema=public
